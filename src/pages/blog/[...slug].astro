---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Estimate reading time
const words = post.body.trim().split(/\s+/).length;
const readingTime = Math.ceil(words / 200) + ' min read';

// Format date
const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(post.data.date);
---

<Layout title={post.data.title} description={post.data.description || `Read ${post.data.title} by ${post.data.author}`}>
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-16 py-12 md:py-20">
    
    <!-- Main Content -->
    <article class="flex-1 min-w-0 max-w-3xl">
      <header class="mb-16">
        <div class="flex items-center gap-3 mb-6 text-sm text-gray-400 font-mono">
          <time datetime={post.data.date.toISOString()} class="text-white/80">{formattedDate}</time>
          <span class="text-white/20">|</span>
          <span>{readingTime}</span>
          <span class="text-white/20">|</span>
          <span class="text-accent">{post.data.author}</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading leading-tight tracking-tight mb-8 text-white">
          {post.data.title}
        </h1>
        
        <div class="flex flex-wrap gap-2">
          {post.data.tags?.map((tag: string) => (
            <a href={`/tags/${tag.toLowerCase()}`} class="px-3 py-1.5 rounded-md bg-surface border border-white/5 text-xs font-mono text-gray-400 hover:text-accent hover:border-accent/40 hover:bg-accent/5 transition-all">
              #{tag}
            </a>
          ))}
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none prose-headings:font-heading prose-headings:font-bold prose-a:text-accent prose-a:font-medium prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-4 prose-blockquote:border-l-accent prose-blockquote:bg-surface/30 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:not-italic prose-blockquote:text-gray-300 prose-blockquote:rounded-r-lg prose-pre:bg-[#0d1117] prose-pre:border prose-pre:border-white/10 prose-img:rounded-xl">
        <Content />
      </div>
      
      <!-- Author Block -->
      <div class="mt-24 p-8 rounded-2xl bg-surface/50 border border-white/5 flex flex-col sm:flex-row gap-6 items-start sm:items-center">
        <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center shrink-0 border border-accent/20">
          <span class="text-2xl font-heading font-bold text-accent">V</span>
        </div>
        <div>
          <h3 class="font-heading font-bold text-xl mb-1 text-white">{post.data.author}</h3>
          <p class="text-gray-400 text-sm leading-relaxed max-w-md">
            Staff Software Engineer bridging the gap between robust platform infrastructure and the frontier of Agentic AI.
          </p>
        </div>
      </div>

      <!-- Footer Actions -->
      <footer class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/blog/" class="text-gray-400 hover:text-white font-mono text-sm transition-colors flex items-center gap-2 group">
          <span class="group-hover:-translate-x-1 transition-transform">&larr;</span> Back to all posts
        </a>
        <a href={`https://github.com/vviswaroop/vviswaroop.github.io/blob/main/src/content/blog/${post.id}`} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-accent font-mono text-sm transition-colors flex items-center gap-2">
          Suggest an edit on GitHub <span class="text-xs">&nearr;</span>
        </a>
      </footer>
    </article>

    <!-- Sidebar / Table of Contents -->
    <aside class="hidden lg:block w-64 shrink-0">
      <div class="sticky top-32">
        <h4 class="font-heading font-semibold text-sm tracking-widest text-white uppercase mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
          On this page
        </h4>
        <nav>
          <ul class="space-y-4 text-sm font-medium text-gray-500">
            {headings.filter(h => h.depth > 1 && h.depth <= 3).map(heading => (
              <li class={`leading-tight ${heading.depth === 3 ? "pl-4" : ""}`}>
                <a href={`#${heading.slug}`} class="block py-1 hover:text-accent transition-colors">
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>

  </div>
</Layout>
