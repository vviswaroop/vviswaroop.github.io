---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Viswaroop Vadlamudi - Staff Software Engineer specializing in identity systems, GitOps, and Kubernetes platforms." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Viswaroop Vadlamudi</title>
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
	</head>
	<body class="min-h-screen flex flex-col relative overflow-x-hidden">
		<!-- Generative background accent (Subtle) -->
		<div class="fixed inset-0 z-[-1] pointer-events-none w-full h-full bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent/10 via-background to-background opacity-60"></div>
		
		<Header />
		
		<main class="flex-grow w-full max-w-4xl mx-auto px-6 py-12 md:py-20">
			<slot />
		</main>
		
		<Footer />
	</body>
</html>
